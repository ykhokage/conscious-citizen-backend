PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/conscious?schema=public"

# JWT
JWT_SECRET="change_me_super_secret"
JWT_EXPIRES_IN="7d"

# Uploads
UPLOAD_DIR="uploads"

# Samara service area bounding box (approx)
SAMARA_MIN_LAT=53.05
SAMARA_MAX_LAT=53.35
SAMARA_MIN_LON=49.95
SAMARA_MAX_LON=50.35

# Nominatim
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"

# Email (optional). If not set, /send-email returns 202 with "queued=false"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="noreply@example.com"
