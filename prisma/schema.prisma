generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

enum IncidentStatus {
  draft
  published
}

model User {
  id        Int      @id @default(autoincrement())
  login     String   @unique
  email     String   @unique
  password  String
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // email verify
  emailVerified Boolean   @default(false)
  emailCodeHash String?
  emailCodeExp  DateTime?

  // reset password
  resetCodeHash String?
  resetCodeExp  DateTime?

  profile       Profile?
  incidents     Incident[]
  notifications Notification[]

  @@index([role])
  @@index([createdAt])
  @@index([emailVerified])
}

model Profile {
  id         Int     @id @default(autoincrement())
  userId     Int     @unique
  surname    String?
  name       String?
  patronymic String?
  phone      String?
  city       String?
  street     String?
  house      String?
  flat       String?
  avatarUrl  String?
  avatarStorageKey String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Incident {
  id          Int            @id @default(autoincrement())
  userId      Int
  category    String
  title       String
  description String
  latitude    Float
  longitude   Float
  address     String
  status      IncidentStatus @default(published)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos        Photo[]
  notifications Notification[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model Photo {
  id         Int      @id @default(autoincrement())
  incidentId Int
  filename   String
  mimeType   String
  size       Int 
  url        String?
  storageKey   String?
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@index([createdAt])
}

model Notification {
  id         Int       @id @default(autoincrement())
  userId     Int
  type       String
  title      String
  body       String?
  href       String
  incidentId Int?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  incident Incident? @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([incidentId])
}